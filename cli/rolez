#!/usr/bin/env python3
"""rolez — agent-side CLI for the rolez registry + provisioner.

Bootstrap inside an agent container:

    curl -fsSL "$ROLEZ_API_URL/cli/rolez" -o /usr/local/bin/rolez && chmod +x /usr/local/bin/rolez

Env vars:
    ROLEZ_API_URL              base URL (e.g., https://rolez.startanaicompany.com)
    ROLEZ_API_KEY              the assistant's tech.saac MCP api key
                                (also accepts MCP_ORCHESTRATOR_API_KEY for parity
                                 with @startanaicompany/techsaac-cli)

Stdlib only — no pip dependencies.
"""
from __future__ import annotations

import argparse
import json
import os
import sys
import urllib.error
import urllib.parse
import urllib.request

EXIT_OK = 0
EXIT_USAGE = 1
EXIT_AUTH = 2
EXIT_NOT_FOUND = 3
EXIT_NETWORK = 4
EXIT_CALLER = 5


def _env(name: str, fallback: str | None = None, required: bool = False) -> str:
    v = os.environ.get(name, fallback)
    if required and not v:
        print(f"rolez: missing required env var {name}", file=sys.stderr)
        sys.exit(EXIT_USAGE)
    return v or ""


def _api_url() -> str:
    return _env("ROLEZ_API_URL", required=True).rstrip("/")


def _api_key() -> str:
    return _env("ROLEZ_API_KEY") or _env("MCP_ORCHESTRATOR_API_KEY", required=True)


def _request(method: str, path: str, body: dict | None = None) -> tuple[int, bytes, dict]:
    url = _api_url() + path
    data = json.dumps(body).encode("utf-8") if body is not None else None
    req = urllib.request.Request(url, data=data, method=method)
    req.add_header("Authorization", f"ApiKey {_api_key()}")
    req.add_header("User-Agent", "rolez-cli/0.1")
    req.add_header("Accept", "application/json")
    if data is not None:
        req.add_header("Content-Type", "application/json")
    try:
        with urllib.request.urlopen(req, timeout=60) as resp:
            return resp.status, resp.read(), dict(resp.headers)
    except urllib.error.HTTPError as e:
        # IncompleteRead can fire if the connection drops mid-body during a
        # 5xx — fall back to a placeholder so the user still gets a clean
        # exit message instead of a Python traceback.
        try:
            body = e.read() if hasattr(e, "read") else b""
        except Exception as read_err:  # noqa: BLE001 — surface a useful diagnostic
            body = f"<could not read response body: {read_err}>".encode()
        return e.code, body, dict(e.headers or {})
    except urllib.error.URLError as e:
        print(f"rolez: network error: {e.reason}", file=sys.stderr)
        sys.exit(EXIT_NETWORK)


def _check(code: int, body: bytes) -> None:
    if code == 401:
        print("rolez: unauthorized (check ROLEZ_API_KEY / MCP_ORCHESTRATOR_API_KEY)", file=sys.stderr)
        sys.exit(EXIT_AUTH)
    if code == 404:
        print(f"rolez: not found: {body.decode(errors='replace')}", file=sys.stderr)
        sys.exit(EXIT_NOT_FOUND)
    if 400 <= code < 500:
        print(f"rolez: client error {code}: {body.decode(errors='replace')}", file=sys.stderr)
        sys.exit(EXIT_CALLER)
    if code >= 500:
        print(f"rolez: server error {code}: {body.decode(errors='replace')}", file=sys.stderr)
        sys.exit(EXIT_NETWORK)


def _json_get(path: str) -> dict | list:
    code, body, _ = _request("GET", path)
    _check(code, body)
    return json.loads(body.decode("utf-8"))


# ---------- commands ----------------------------------------------------

def cmd_list(args: argparse.Namespace) -> int:
    qs = []
    if args.tag:
        qs.append(f"tag={urllib.parse.quote(args.tag)}")
    if args.kind:
        qs.append(f"kind={urllib.parse.quote(args.kind)}")
    path = "/api/v1/roles" + (("?" + "&".join(qs)) if qs else "")
    data = _json_get(path)
    items = data.get("items", []) if isinstance(data, dict) else []
    if args.json:
        print(json.dumps(items, indent=2))
        return EXIT_OK
    if not items:
        print("(no roles)")
        return EXIT_OK
    name_w = max((len(i["slug"]) for i in items), default=4)
    ver_w = max((len(i.get("latest_version") or "-") for i in items), default=7)
    for i in items:
        print(
            f"{i['slug']:<{name_w}}  {(i.get('latest_version') or '-'):<{ver_w}}  {i.get('description') or ''}"
        )
    return EXIT_OK


def cmd_search(args: argparse.Namespace) -> int:
    data = _json_get(f"/api/v1/roles/search?q={urllib.parse.quote(args.query)}")
    items = data.get("items", []) if isinstance(data, dict) else []
    if args.json:
        print(json.dumps(items, indent=2))
        return EXIT_OK
    for i in items:
        print(f"{i['slug']} ({i.get('latest_version') or '-'}) — {i.get('description') or ''}")
    return EXIT_OK


def cmd_show(args: argparse.Namespace) -> int:
    name, version = _split_versioned(args.target)
    path = f"/api/v1/roles/{name}"
    if version:
        path = f"/api/v1/roles/{name}/versions/{version}"
    data = _json_get(path)
    print(json.dumps(data, indent=2))
    return EXIT_OK


def cmd_inspect(args: argparse.Namespace) -> int:
    """Show + briefly summarise each referenced skill/subagent."""
    name, version = _split_versioned(args.target)
    path = f"/api/v1/roles/{name}"
    if version:
        path = f"/api/v1/roles/{name}/versions/{version}"
    data = _json_get(path)
    manifest = data.get("manifest") if isinstance(data, dict) else None
    if not manifest:
        print(json.dumps(data, indent=2))
        return EXIT_OK
    print(f"role:      {data.get('slug', name)}@{data.get('latest_version') or version or '?'}")
    print(f"image:     {manifest['image']['ref']}@{manifest['image']['version']}")
    print("skills:")
    for s in manifest.get("skills", []):
        print(f"  - {s['name']}@{s['version']}")
    print("subagents:")
    for a in manifest.get("subagents", []):
        print(f"  - {a['name']}@{a['version']}")
    print(f"context_files: {[f['name'] for f in manifest.get('context_files', [])]}")
    return EXIT_OK


# ---------- helpers ------------------------------------------------------

def _split_versioned(arg: str) -> tuple[str, str | None]:
    if "@" in arg:
        a, b = arg.split("@", 1)
        return a, b
    return arg, None


# ---------- entrypoint ---------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="rolez", description="Role registry + provisioner CLI.")
    sub = p.add_subparsers(dest="command", required=True)

    pl = sub.add_parser("list")
    pl.add_argument("--tag")
    pl.add_argument("--kind", choices=["agent", "assistant"])
    pl.add_argument("--json", action="store_true")
    pl.set_defaults(func=cmd_list)

    ps = sub.add_parser("search")
    ps.add_argument("query")
    ps.add_argument("--json", action="store_true")
    ps.set_defaults(func=cmd_search)

    psh = sub.add_parser("show")
    psh.add_argument("target", help="slug[@version]")
    psh.set_defaults(func=cmd_show)

    pi = sub.add_parser("inspect")
    pi.add_argument("target", help="slug[@version]")
    pi.set_defaults(func=cmd_inspect)

    return p


def main(argv: list[str] | None = None) -> int:
    try:
        args = build_parser().parse_args(argv)
        return args.func(args)
    except SystemExit as e:
        # Errors inside command handlers use sys.exit() to bail out — convert
        # to a return code so callers (incl. tests) can inspect it.
        if isinstance(e.code, int):
            return e.code
        return EXIT_USAGE


if __name__ == "__main__":
    sys.exit(main())
