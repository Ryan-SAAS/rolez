            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Show Role Version Api Admin Roles  Slug  Versions  Version  Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
