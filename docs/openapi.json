      "get": {
        "description": "Returns the role's metadata + the **latest version's manifest** + sha256\nso the AdminOffice and tech.saac's daemon-config builder can render /\nconsume the role in a single round-trip.",
        "operationId": "show_role_api_admin_roles__slug__get",
        "parameters": [
          {
            "in": "path",
