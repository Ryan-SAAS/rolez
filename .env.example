# Database — on Railway this is injected automatically as DATABASE_URL
DATABASE_URL=postgresql+asyncpg://rolez:rolez@db:5432/rolez

# Admin API key. Used by tech.saac for role-template CRUD (binding images,
# skills, subagents, context files into roles). Single env-var, ApiKey scheme.
ROLEZ_ADMIN_API_KEY=change-me-admin-api-key

# CORS allow-list for the admin UI at tech.startanaicompany.com
ADMIN_ALLOWED_ORIGINS=https://tech.startanaicompany.com,http://localhost:3000

# /metrics HTTP Basic credentials (Prometheus scrape)
METRICS_USER=metrics
METRICS_PASS=change-me-metrics

# Upstream registries — read-only service tokens, used only when rolez
# itself initiates a sync (resolving "latest" → pinned version at admin
# save time). The assistant's own token is reused for provisioning.
SKILLZ_API_URL=https://skillz.startanaicompany.com
SKILLZ_TOKEN=
AGENTZ_API_URL=https://agentz.startanaicompany.com
AGENTZ_TOKEN=

# tech.saac — used both for the validation probe and as the downstream call
# URL. There is no rolez-side service token for tech.saac; assistants pass
# their own MCP_ORCHESTRATOR_API_KEY through and rolez verifies it upstream.
MCP_ORCHESTRATOR_URL=https://tech.startanaicompany.com/api/mcp
ROLEZ_AUTH_TTL_SECONDS=60

# Public URL of this service — used when the server advertises its own CLI URL
ROLEZ_PUBLIC_URL=http://localhost:8000

PORT=8000
